<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FrankenPHP on Clever Cloud{% endblock %}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
      :root {
        --bg: #07080C;
        --surface: #0C0E13;
        --border: #1A1D26;
        --text: #E6E8F0;
        --muted: #4E5468;
        --accent: #FF5A1F;
        --green: #22c55e;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        min-height: 100%;
        font-family: 'Outfit', sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover { text-decoration: underline; }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 40px 20px 60px;
      }

      .hero,
      .card,
      .footer-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 18px;
      }

      .hero {
        padding: 32px;
        margin-bottom: 24px;
      }

      .eyebrow {
        display: inline-block;
        margin-bottom: 14px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(255, 90, 31, 0.1);
        color: var(--accent);
        border: 1px solid rgba(255, 90, 31, 0.22);
        font-size: 14px;
        font-weight: 600;
      }

      h1 {
        margin: 0 0 16px;
        font-size: 46px;
        line-height: 1.05;
        color: var(--text);
      }

      .accent { color: var(--accent); }

      .lead {
        margin: 0;
        max-width: 760px;
        font-size: 19px;
        line-height: 1.6;
        color: var(--muted);
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border-radius: 10px;
        font-weight: 600;
        border: 1px solid transparent;
        text-decoration: none;
        transition: all 0.15s;
        font-family: 'Outfit', sans-serif;
      }

      .button-primary {
        background: var(--accent);
        color: var(--bg);
      }

      .button-primary:hover {
        background: #E8491A;
        text-decoration: none;
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(255, 90, 31, 0.22);
        color: var(--bg);
      }

      .button-secondary {
        background: rgba(255, 90, 31, 0.08);
        color: var(--accent);
        border-color: rgba(255, 90, 31, 0.22);
      }

      .button-secondary:hover {
        background: rgba(255, 90, 31, 0.15);
        text-decoration: none;
        color: var(--accent);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 20px;
        margin-bottom: 24px;
      }

      .card { padding: 24px; }

      .col-4  { grid-column: span 4; }
      .col-6  { grid-column: span 6; }
      .col-8  { grid-column: span 8; }
      .col-12 { grid-column: span 12; }

      .card h2 {
        margin-top: 0;
        margin-bottom: 10px;
        font-size: 22px;
        color: var(--text);
      }

      .card p,
      .card li {
        color: var(--muted);
        line-height: 1.6;
      }

      .metric {
        display: block;
        margin-top: 8px;
        font-size: 28px;
        font-weight: 600;
        color: var(--text);
        font-family: 'DM Mono', monospace;
      }

      .metric-sub {
        display: block;
        margin-top: 8px;
        color: var(--muted);
        font-size: 14px;
      }

      .list {
        margin: 0;
        padding-left: 18px;
      }

      .logo-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 260px;
      }

      .logo-wrap img {
        max-width: 100%;
        height: auto;
      }

      .footer-card { padding: 20px 24px; }
      .footer-card p { margin: 0; color: var(--muted); }

      code {
        padding: 2px 6px;
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        color: var(--accent);
        font-family: 'DM Mono', monospace;
        font-size: 0.9em;
      }

      @media (max-width: 900px) {
        h1 { font-size: 34px; }
        .col-4, .col-6, .col-8, .col-12 { grid-column: span 12; }
      }
    </style>

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
  </head>
  <body>
    {% block body %}{% endblock %}
  </body>
</html>
